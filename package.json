    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.2.3",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "markuplint": "^4.12.0",
    "prettier": "^3.5.3",
